<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  PrivacyInfo.xcprivacy — Apple Privacy Manifest
  Required for App Store submissions since Spring 2024.

  Y2Notes uses zero third-party SDKs and does not collect user data.
  This manifest declares the required reason APIs the app accesses.
-->
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<!--
		  File timestamp APIs (NSFileCreationDate, NSFileModificationDate)
		  Used by NoteStore for backup file management and save ordering.
		  Reason: C617.1 — Access file timestamps for app functionality.
		-->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
		<!--
		  UserDefaults API
		  Used by InkEffectStore, AppSettingsStore, ThemeStore for preferences.
		  Reason: CA92.1 — Access user defaults for app functionality.
		-->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<!--
		  System boot time API (ProcessInfo.processInfo.systemUptime)
		  Used indirectly by Core Animation (CAEmitterLayer) for particle timing.
		  Reason: 35F9.1 — Access system boot time for measuring elapsed time.
		-->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>35F9.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
