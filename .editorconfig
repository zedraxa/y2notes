# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across all editors and contributors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.swift]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,plist}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.strings]
indent_size = 4

[Makefile]
indent_style = tab

[*.{xcscheme,xcworkspacedata}]
indent_size = 3
